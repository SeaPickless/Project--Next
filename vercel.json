{
  "version": 2,
  "builds": [
    { "src": "api/*.js", "use": "@vercel/node" },
    { "src": "index.html", "use": "@vercel/static" }
  ],
  "routes": [
    { "src": "/api/friends", "dest": "/api/friends.js" },
    { "src": "/api/inventory", "dest": "/api/inventory.js" },
    { "src": "/(.*)", "dest": "/index.html" }
  ]
}
