{
  "version": 2,
  "builds": [
    { "src": "api/proxy.js",  "use": "@vercel/node" },
    { "src": "index.html",   "use": "@vercel/static" }
  ],
  "routes": [
    {
      "src": "/api/proxy",
      "dest": "/api/proxy.js",
      "headers": {
        "Access-Control-Allow-Origin":  "*",
        "Access-Control-Allow-Methods": "GET, POST, OPTIONS",
        "Access-Control-Allow-Headers": "Content-Type, Authorization"
      }
    },
    { "src": "/(.*)", "dest": "/index.html" }
  ]
}
